# Backend (Go) environment

# Postgres connection string (required).
# For a local Docker run:
#   docker run -d --name sajni-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=sajni postgres:16
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sajni?sslmode=disable

# Secret used to sign JWT access tokens (required). Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Storage backend: "local" (default) or "gcs"
STORAGE_BACKEND=local

# When STORAGE_BACKEND=local, where to put the on-disk blob tree
STORAGE_LOCAL_DIR=./data/blobs

# When STORAGE_BACKEND=gcs, the bucket to use
# GCS_BUCKET=sajni-blobs
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# CORS: the exact frontend origin to allow (required in prod, e.g. https://sajni.vercel.app).
# Leave blank in dev to reflect any origin.
# If DEV_AUTH_BYPASS=1, localhost/private-network origins are also allowed for
# direct phone testing, even when CORS_ORIGIN is pinned to localhost.
CORS_ORIGIN=

# Set to 1 in dev so the refresh-token cookie is delivered over plain HTTP
# from localhost (drops Secure, uses SameSite=Lax). In prod leave unset.
COOKIE_INSECURE=1

# Local/demo auth bypass. When set to 1, POST /api/auth/refresh mints a normal
# session for DEV_AUTH_BYPASS_EMAIL, but only for localhost/private-network
# request origins such as http://localhost:5173 or http://192.168.x.x:5173.
# Never set this in production.
DEV_AUTH_BYPASS=0
DEV_AUTH_BYPASS_EMAIL=dev@sajni.local
DEV_AUTH_BYPASS_NAME=Sajni Dev

# Optional integrations
TMDB_API_KEY=

# AI (Gemini). Leaving GEMINI_API_KEY blank disables the @sajni palette
# mode and the sidebar chat panel — endpoints respond with 503 and the
# UI hides the affordances.
GEMINI_API_KEY=
# Default model — gemini-2.5-flash is the cheapest tier that reliably
# continues the agent loop after function calls. -lite is cheaper but
# tends to go silent after tool rounds.
GEMINI_MODEL=gemini-2.5-flash

# ─── Auth (OAuth + email TOTP) ────────────────────────────────────────
# APP_URL is the user-facing web origin — used to build redirect URLs
# back to the SPA after an OAuth callback or email link.
APP_URL=http://localhost:5173

# API_BASE_URL is the direct API origin fallback used for OAuth callback
# URLs when the request did not arrive through the frontend /api proxy.
# In production with the Vercel /api rewrite, register the frontend
# callback URL too, and set APP_URL to the canonical frontend origin:
#   https://www.ohmysajni.com/api/auth/google/callback    (prod proxy)
#   http://localhost:8080/api/auth/google/callback       (dev fallback)
API_BASE_URL=http://localhost:8080

# Cloud Tasks reminder delivery. Leave CLOUD_TASKS_QUEUE blank in local dev to
# skip enqueueing; the internal reminder sweep can still be called manually.
CLOUD_TASKS_PROJECT=
CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_QUEUE=

# Google OAuth 2.0 — create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth — create at https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Resend (email-delivered TOTP) — create at https://resend.com.
# If RESEND_API_KEY is blank, the API logs codes to stdout instead of
# sending real email (handy for local dev).
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Internal webhook secrets used by Cloud Scheduler / Cloud Tasks.
REMINDER_CRON_SECRET=
PRICE_CRON_SECRET=
